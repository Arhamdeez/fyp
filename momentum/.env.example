# Server
PORT=5000
# Listen on all interfaces so phones on the same Wi‑Fi can reach the API (default in code is 0.0.0.0)
HOST=0.0.0.0
NODE_ENV=development
# Production: comma-separated allowed web origins. Omit in development (LAN + localhost allowed).
# CORS_ORIGIN=https://yourapp.com,http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/momentum
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# External APIs
WEATHER_API_KEY=your_openweathermap_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Client
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key
